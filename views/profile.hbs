<div class="text-black">
    <h1 class="mb-4">Mein Profil</h1>
    <p><strong>E-Mail:</strong> {{email}}</p>
    <p><strong>Registriert seit:</strong> {{createdAt}}</p>

    <hr class="my-4">

    <h5 class="fw-semibold mb-1">Spitzname</h5>
    <p class="text-muted small mb-3">Wird in Gruppen anstelle deines Benutzernamens angezeigt.</p>
    <form method="post" action="/profile/nickname">
        <div class="input-group" style="max-width: 400px;">
            <input type="text" class="form-control" name="nickname" placeholder="z.B. Max" value="{{nickname}}">
            <button type="submit" class="btn btn-dark">Speichern</button>
        </div>
    </form>

    <a href="/dashboard" class="btn btn-outline-dark mt-4">Zurück zum Dashboard</a>
</div>
