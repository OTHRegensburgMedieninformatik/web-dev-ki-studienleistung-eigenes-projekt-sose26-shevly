<h1 class="mb-4">Gruppen</h1>

{{#if groups.length}}
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Erstellt am</th>
        </tr>
        </thead>
        <tbody>
        {{#each groups}}
            <tr>
                <td>{{this.name}}</td>
                <td>{{this.created_at}}</td>
            </tr>
        {{/each}}
        </tbody>
    </table>
{{else}}
    <p class="text-muted">Noch keine Gruppen vorhanden.</p>
{{/if}}

<form method="post" action="/groups/create">
    <div class="mb-3">
        <label for="name" class="form-label text-black">Gruppenname</label>
        <input type="text" class="form-control" id="name" name="name" placeholder="z.B. Urlaub 2026" required>
    </div>
    <button type="submit" class="btn btn-primary">Gruppe erstellen</button>
</form>
